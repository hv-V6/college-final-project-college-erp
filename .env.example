# ============================================================
# College ERP — Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# ----- Database -----
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=college_erp
MYSQL_USER=erp_user
MYSQL_PASSWORD=change_this_db_password

# ----- Domain / IP -----
# Set to your domain (e.g. mydomain.com) OR your VPS IP (e.g. 103.45.67.89)
# If using IP, SSL will be disabled automatically
DOMAIN=your-domain-or-ip

# ----- SSL (only used if DOMAIN is set to a real domain, not an IP) -----
# Set to true to enable HTTPS via Let's Encrypt
ENABLE_SSL=false

# ----- App Port (only used when NOT behind nginx, e.g. local dev) -----
APP_PORT=8080